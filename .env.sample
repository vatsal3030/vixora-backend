NODE_ENV=development
# In production strict validation is on by default; set true locally if needed.
ENV_VALIDATE_STRICT=false
PORT=10000

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Database (PostgreSQL - Neon)
DATABASE_URL=postgresql://username:password@host/dbname
# Optional: dedicated shadow DB used by `prisma migrate dev` (local/dev only).
# Example: postgresql://username:password@host/dbname_shadow
# Never point this to production data DB.
SHADOW_DATABASE_URL=

# JWT
ACCESS_TOKEN_SECRET=your_access_token_secret
ACCESS_TOKEN_EXPIRY=1d

REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRY=7d
# Optional secret for multi-account switch token signing.
# Defaults to REFRESH_TOKEN_SECRET when omitted.
ACCOUNT_SWITCH_SECRET=your_account_switch_secret
ACCOUNT_SWITCH_EXPIRY=30d
# Optional dedicated secret for forgot-password step-2 reset token
PASSWORD_RESET_TOKEN_SECRET=your_password_reset_token_secret
PASSWORD_RESET_TOKEN_EXPIRY=10m

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:10000/api/v1/auth/google/callback
# Optional: use the exact GOOGLE_CALLBACK_URL above instead of request host.
# Keep this false unless you intentionally want a single fixed callback host.
GOOGLE_FORCE_CALLBACK_URL=false

# Email (Brevo SMTP)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=Vixora <your_email@gmail.com>

# Frontend
FRONTEND_URL=http://localhost:5173
# Optional separate admin frontend origin (if you host admin panel separately).
ADMIN_FRONTEND_URL=http://localhost:5173
# Admin panel exposure toggle.
ADMIN_PANEL_ENABLED=true
# Comma-separated emails to auto-promote to SUPER_ADMIN on startup.
ADMIN_BOOTSTRAP_EMAILS=

# AI (Gemini)
# Keep empty to disable external AI provider and use fallback responses.
GEMINI_API_KEY=
# Optional comma-separated model fallback order.
GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-flash-latest
# Max characters returned from AI text generation (hard-capped in code).
AI_MAX_OUTPUT_CHARS=3000
# Daily AI messages/user across AI chat + ask routes.
AI_DAILY_MESSAGE_LIMIT=40
# Optional global daily cap for all users combined (0 = disabled).
AI_GLOBAL_DAILY_MESSAGE_LIMIT=0

# WebSocket (real-time notifications)
SOCKET_ENABLED=true
SOCKET_PATH=/socket.io
# Internal observability endpoint auth (GET /api/v1/internal/usage)
INTERNAL_METRICS_TOKEN=change_this_internal_token

# Redis / Queue (optional)
# If you don't use Redis, keep REDIS_ENABLED=false and leave REDIS_* empty.
REDIS_ENABLED=false
# Log throttling for transient Redis network errors (milliseconds).
REDIS_ERROR_LOG_COOLDOWN_MS=30000
# Run worker only when you need background queue processing in production.
RUN_WORKER=false
# On-demand worker: starts when job arrives, stops after idle timeout.
RUN_WORKER_ON_DEMAND=true
# Queue producer/consumer feature flag (lets API enqueue without running worker).
QUEUE_ENABLED=true
# Reduce retries to avoid Redis command spikes on free tier.
QUEUE_JOB_ATTEMPTS=2
QUEUE_JOB_BACKOFF_MS=3000
# Reject enqueue when queue is too deep (fallbacks to direct processing).
QUEUE_MAX_WAITING_JOBS=25
# Idle auto-shutdown for on-demand worker (milliseconds).
WORKER_IDLE_SHUTDOWN_MS=45000
# Worker runtime tuning.
WORKER_CONCURRENCY=1
WORKER_ERROR_LOG_COOLDOWN_MS=30000
# Optional: hide BullMQ startup version/eviction warnings in managed Redis.
BULLMQ_SKIP_VERSION_CHECK=true
# Set REDIS_ENABLED=true only when REDIS_URL or REDIS_HOST is valid.
# REDIS_URL=rediss://username:password@host:port
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Cache (selective endpoint cache for feed/channel/video detail)
# Requires REDIS_ENABLED=true and valid REDIS_URL/REDIS_HOST settings.
CACHE_ENABLED=false
CACHE_L1_ENABLED=true
CACHE_L1_MAX_ENTRIES=300
CACHE_DEFAULT_TTL_SECONDS=30
CACHE_NAMESPACE=vixora
# Redis cache layer toggle (L2). In production this defaults to false in code.
CACHE_REDIS_ENABLED=false
# Only write keys to Redis cache when TTL >= this threshold.
CACHE_REDIS_MIN_TTL_SECONDS=60
# Optional allowlist for Redis cache scopes (comma-separated). Empty = all scopes.
# Example: video:detail,channel:info,channel:about
CACHE_REDIS_SCOPE_ALLOWLIST=video:detail,channel:info,channel:about

# Notification fanout guard: skip duplicate channel activity notifications
# for the same user/activity/video within this time window.
NOTIFICATION_DEDUP_WINDOW_MINUTES=30

# Recalculate popularity/engagement score every Nth view (watch endpoint).
VIDEO_SCORE_RECALC_VIEW_INTERVAL=5

# Cron / batch
NIGHT_BATCH_LIMIT=20
RUN_SCHEDULER=false
TZ=Asia/Kolkata

# Upload session security window (minutes)
UPLOAD_SESSION_TTL_MINUTES=120
